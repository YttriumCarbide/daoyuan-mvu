{
  "name": "status-placeholder",
  "version": "1.0.0",
  "description": "Vite + Vue + Zod development environment for MVU Status Bar",
  "main": "src/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tavern": "vite --config tavern/vite.config.js",
    "dev:iframe": "vite --config vite.iframe.config.js",
    "build": "vite build && node scripts/build-post.js",
    "extract": "node scripts/extract.js",
    "kill": "node scripts/kill-port.js"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "node-html-parser": "^9.0.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^5.2.0",
    "vite-plugin-singlefile": "^2.0.1"
  }
}
